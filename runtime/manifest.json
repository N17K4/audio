{
  "_comment": "产物固化清单（Artifact Pinning Manifest）。pip_packages 在构建期装入 embedded Python；runtime_pip_packages 在首次启动时装入 userData/python-packages/。",
  "manifest_version": "1",
  "engines": {
    "fish_speech": {
      "version": "s1-mini",
      "_note": "引擎已升级至 S1/S2 API，需 fishaudio/openaudio-s1-mini checkpoint（gated model，下载前需 HuggingFace 登录并接受条款）",
      "code_dir": "runtime/fish_speech/engine",
      "checkpoint_dir": "checkpoints/fish_speech",
      "pip_packages": [
        "setuptools", "wheel",
        "loguru", "natsort", "soundfile", "loralib",
        "pyrootutils", "pydantic", "rich", "click", "tqdm"
      ],
      "runtime_pip_packages": [
        "torch", "torchaudio",
        "lightning", "hydra-core", "transformers",
        "descript-audio-codec", "descript-audiotools", "einops"
      ],
      "checkpoint_files": [
        {
          "path": "model.pth",
          "url": "https://huggingface.co/fishaudio/openaudio-s1-mini/resolve/main/model.pth",
          "size_mb": 1740,
          "required": true
        },
        {
          "path": "codec.pth",
          "url": "https://huggingface.co/fishaudio/openaudio-s1-mini/resolve/main/codec.pth",
          "size_mb": 1870,
          "required": true
        },
        {
          "path": "config.json",
          "url": "https://huggingface.co/fishaudio/openaudio-s1-mini/resolve/main/config.json",
          "size_mb": 1,
          "required": true
        },
        {
          "path": "tokenizer.tiktoken",
          "url": "https://huggingface.co/fishaudio/openaudio-s1-mini/resolve/main/tokenizer.tiktoken",
          "size_mb": 1,
          "required": true
        },
        {
          "path": "special_tokens.json",
          "url": "https://huggingface.co/fishaudio/openaudio-s1-mini/resolve/main/special_tokens.json",
          "size_mb": 1,
          "required": false
        }
      ],
      "env_key": "FISH_SPEECH_CHECKPOINT_DIR"
    },
    "seed_vc": {
      "version": "2.0",
      "code_dir": "runtime/seed_vc/engine",
      "checkpoint_dir": "checkpoints/seed_vc",
      "pip_packages": [
        "setuptools", "wheel", "huggingface_hub"
      ],
      "runtime_pip_packages": [
        "torch", "torchaudio",
        "numpy", "scipy", "librosa==0.10.2",
        "soundfile", "einops", "omegaconf", "transformers"
      ],
      "checkpoint_files": [
        {
          "path": "DiT_seed_v2_uvit_whisper_small_wavenet_bigvgan_pruned.pth",
          "sha256": "8ec8841b20bb46df9f7e8e570a6946a4b87b940133c7f0e778487ff33841f720",
          "url": "https://huggingface.co/Plachta/Seed-VC/resolve/main/DiT_seed_v2_uvit_whisper_small_wavenet_bigvgan_pruned.pth",
          "size_mb": 200,
          "required": true
        },
        {
          "path": "config_dit_mel_seed_uvit_whisper_small_wavenet.yml",
          "sha256": "27a91ac41bdb41d0b6951c63642d791b4a70d60b9fc5550eb645f9ddcb3c94da",
          "url": "https://huggingface.co/Plachta/Seed-VC/resolve/main/config_dit_mel_seed_uvit_whisper_small_wavenet.yml",
          "size_mb": 1,
          "required": true
        }
      ],
      "hf_cache_downloads": [
        {
          "repo_id": "funasr/campplus",
          "filename": "campplus_cn_common.bin",
          "cache_dir_rel": "checkpoints",
          "size_mb": 25,
          "note": "说话人特征提取（campplus）"
        },
        {
          "repo_id": "nvidia/bigvgan_v2_22khz_80band_256x",
          "cache_dir_rel": "checkpoints/hf_cache",
          "size_mb": 1300,
          "note": "BigVGAN 声码器（仅 generator，跳过 discriminator/3msteps）",
          "ignore_patterns": [
            "bigvgan_generator_3msteps.pt",
            "bigvgan_discriminator_optimizer.pt",
            "bigvgan_discriminator_optimizer_3msteps.pt"
          ]
        },
        {
          "repo_id": "openai/whisper-small",
          "cache_dir_rel": "checkpoints/hf_cache",
          "size_mb": 950,
          "note": "Whisper-small 语义特征编码器（仅 safetensors，跳过 pytorch/flax/tf 格式）",
          "ignore_patterns": [
            "pytorch_model.bin",
            "flax_model.msgpack",
            "tf_model.h5",
            "rust_model.ot",
            "model.ckpt*"
          ]
        },
        {
          "repo_id": "lj1995/VoiceConversionWebUI",
          "filename": "rmvpe.pt",
          "cache_dir_rel": "checkpoints",
          "size_mb": 200,
          "note": "RMVPE F0 提取器，seed-vc f0_condition=True 时需要"
        }
      ],
      "env_key": "SEED_VC_CHECKPOINT_DIR"
    },
    "rvc": {
      "version": "2.0",
      "code_dir": "runtime/rvc/engine",
      "checkpoint_dir": "checkpoints/rvc",
      "checkpoint_files": [],
      "pip_packages": ["rvc-python"],
      "runtime_pip_packages": [
        "torch", "torchaudio",
        "av", "faiss-cpu", "ffmpeg-python", "praat-parselmouth", "pyworld", "torchcrepe"
      ],
      "env_key": "RVC_CHECKPOINT_DIR"
    },
    "whisper": {
      "version": "large-v3",
      "code_dir": "runtime/whisper/engine",
      "checkpoint_dir": "checkpoints/whisper",
      "checkpoint_files": [
        {
          "path": "model.pt",
          "sha256": "e5b1a55b89c1367dacf97e3e19bfd829a01529dbfdeefa8caeb59b3f1b81dadb",
          "size_mb": 1550,
          "required": false,
          "_note": "非必填：transformers pipeline 会自动缓存，或指定 hf model id；不预置 url 避免 CI 白白下载 1.5 GB"
        }
      ],
      "env_key": "WHISPER_CHECKPOINT_DIR"
    }
  }
}
