# 默认：文本文件自动检测，统一使用 LF 行尾
* text=auto eol=lf

# 明确声明文本文件
*.py    text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf

# Windows 批处理脚本保留 CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf

# 二进制模型文件：禁止任何文本转换，防止损坏
*.pth        binary
*.pt         binary
*.onnx       binary
*.safetensors binary
*.ckpt       binary
*.bin        binary
*.pyd        binary
*.so         binary
*.dylib      binary
*.dll        binary
*.index      binary

# 音频文件
*.wav        binary
*.mp3        binary
*.flac       binary
*.ogg        binary
*.webm       binary

# 图片
*.png        binary
*.jpg        binary
*.jpeg       binary
*.ico        binary
*.icns       binary
