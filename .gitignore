# ─── JS / Node ────────────────────────────────────────────────────────────────
node_modules/
package-lock.json
frontend/next-env.d.ts
frontend/out/
.next
*.tsbuildinfo

# ─── 构建产物 ─────────────────────────────────────────────────────────────────
dist/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/

# ─── 模型权重（user_data/ 目录下） ────────────────────────────────────────────
user_data/**/*.pth
user_data/**/*.onnx
user_data/**/*.pt
user_data/**/*.ckpt
user_data/**/*.safetensors
user_data/**/*.index

# ─── 用户创建的 RVC 音色（运行时数据，不跟踪） ──────────────────────────────────
user_data/rvc/user/*
!user_data/rvc/user/.gitkeep

# ─── 用户创建的 Seed-VC 音色（运行时数据，不跟踪） ──────────────────────────────
user_data/seed_vc/user/*
!user_data/seed_vc/user/.gitkeep

# ─── Fish Speech 微调输出（运行时数据，不跟踪） ──────────────────────────────────
user_data/fish_speech/*
!user_data/fish_speech/.gitkeep

# ─── 用户创建的知识库（RAG，运行时数据，不跟踪） ─────────────────────────────────
user_data/rag/user/*
!user_data/rag/user/.gitkeep

# ─── Agent 工作区（運行時数据，不跟踪） ──────────────────────────────────────────
user_data/agent/*
!user_data/agent/.gitkeep

# ─── runtime 目录 ─────────────────────────────────────────────────────────────
# 忽略 runtime/ 下的非引擎内容（嵌入式 Python、bin、checkpoints、ML 包）
runtime/*
# engine 源码已 git 跟踪（含各引擎 LICENSE）
!runtime/engine/

# ─── 无独立源码的引擎（rvc 通过 rvc-python pip 包推理，无需引擎目录）────────
runtime/engine/rvc/
# ─── 不可再分发的引擎（OpenRAIL-AS 许可证，setup 时 git clone）──────────────
runtime/engine/facefusion/

# ─── checkpoints / 大模型（已整合至 runtime/checkpoints/，保留以防旧目录残留）──
checkpoints/

# ─── 本地开发 ML 包（已整合至 runtime/ml/，保留以防旧目录残留）──────────────
local_data/

# ─── 引擎独立 pip 包目录（如 facefusion 等）──────────────────────────────────
facefusion-packages/

# ─── 运行时数据 ──────────────────────────────────────────────────────────────
backend/.jobs/
cache/

# ─── 日志 & 临时文件 ───────────────────────────────────────────────────────────
*.log
logs/
temp/

# ─── 系统 & IDE ───────────────────────────────────────────────────────────────
.DS_Store
*.zip
*.exe
*.pdb

# ─── Claude 相关（本地开发工具，不进版本库） ──────────────────────────────────
.claude
CLAUDE*
AGENT*
README.md
*memorybank*

.env