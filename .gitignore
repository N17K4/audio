# ─── JS / Node ────────────────────────────────────────────────────────────────
node_modules/
package-lock.json
frontend/next-env.d.ts
frontend/out/
.next
*.tsbuildinfo

# ─── 构建产物 ─────────────────────────────────────────────────────────────────
dist/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/

# ─── 模型权重（models/ 目录下） ────────────────────────────────────────────────
models/**/*.pth
models/**/*.onnx
models/**/*.pt
models/**/*.ckpt
models/**/*.safetensors
models/**/*.index

# ─── 用户创建的音色（运行时数据，不跟踪） ──────────────────────────────────────
models/voices/user/*
!models/voices/user/.gitkeep

# ─── 微调输出（运行时数据，不跟踪） ──────────────────────────────────────────
models/finetune/*
!models/finetune/.gitkeep

# ─── 用户创建的知识库（RAG，运行时数据，不跟踪） ─────────────────────────────────
models/rag/user/*
!models/rag/user/.gitkeep

# ─── runtime 目录 ─────────────────────────────────────────────────────────────
# 忽略 runtime/ 下的非引擎内容（嵌入式 Python、bin、checkpoints、ML 包）
runtime/*
# engine 源码已 git 跟踪（含各引擎 LICENSE）
!runtime/engine/

# ─── checkpoints / 大模型（已整合至 runtime/checkpoints/，保留以防旧目录残留）──
checkpoints/

# ─── 本地开发 ML 包（已整合至 runtime/ml/，保留以防旧目录残留）──────────────
local_data/

# ─── 引擎独立 pip 包目录（如 facefusion 等）──────────────────────────────────
facefusion-packages/

# ─── 运行时数据 ──────────────────────────────────────────────────────────────
backend/.jobs/
cache/

# ─── 日志 & 临时文件 ───────────────────────────────────────────────────────────
*.log
logs/
temp/

# ─── 系统 & IDE ───────────────────────────────────────────────────────────────
.DS_Store
*.zip
*.exe
*.pdb

# ─── Claude 相关（本地开发工具，不进版本库） ──────────────────────────────────
.claude
CLAUDE*
AGENT*
README.md
*memorybank*

.env