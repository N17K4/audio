{
  "name": "ai-workshop",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "predev": "pkill -f 'next dev' 2>/dev/null; pkill -f 'next-server' 2>/dev/null; pkill -f 'AI Workshop' 2>/dev/null; pkill -f 'electron-builder' 2>/dev/null; pkill -f 'uvicorn main:app' 2>/dev/null; true",
    "dev": "concurrently -n 前端,Electron -c cyan,yellow \"cd frontend && pnpm dev\" \"wait-on http://localhost:3000 && npx electron .\"",
    "setup": "bash scripts/setup.sh",
    "runtime": "bash scripts/runtime.sh",
    "ml": "runtime/python/mac/bin/python3 scripts/ml_base.py",
    "ml:extra": "runtime/python/mac/bin/python3 scripts/ml_extra.py",
    "ml:rag": "runtime/python/mac/bin/python3 scripts/ml_extra.py --group rag",
    "ml:agent": "runtime/python/mac/bin/python3 scripts/ml_extra.py --group agent",
    "ml:lora": "runtime/python/mac/bin/python3 scripts/ml_extra.py --group lora",
    "checkpoints": "runtime/python/mac/bin/python3 scripts/checkpoints_base.py",
    "checkpoints:check": "runtime/python/mac/bin/python3 scripts/checkpoints_base.py --check-only",
    "checkpoints:force": "runtime/python/mac/bin/python3 scripts/checkpoints_base.py --force",
    "checkpoints:extra": "runtime/python/mac/bin/python3 scripts/checkpoints_extra.py",
    "clean": "rm -rf runtime/ml runtime/checkpoints runtime/engine && echo '✓ 已清除 ML 依赖、checkpoints、引擎源码'",
    "reinstall": "pnpm run clean && pnpm run setup && pnpm run ml && pnpm run checkpoints",
    "all": "pnpm run setup && pnpm run runtime && pnpm run ml && pnpm run checkpoints && pnpm run dev",
    "build:frontend": "cd frontend && pnpm build",
    "predist": "pkill -f 'next dev' 2>/dev/null; pkill -f 'next-server' 2>/dev/null; pkill -f 'AI Workshop' 2>/dev/null; pkill -f 'Electron.*test001' 2>/dev/null; true",
    "dist": "bash scripts/dist.sh --mac",
    "dist:win": "bash scripts/dist.sh --win",
    "dist:both": "bash scripts/dist.sh --mac && bash scripts/dist.sh --win",
    "dist2:win": "pnpm run setup && pnpm run runtime && pnpm run ml && pnpm run checkpoints && bash scripts/dist.sh --win --full",
    "docker": "docker compose up --build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-reload": "2.0.0-alpha.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.ai.voice",
    "productName": "AI Workshop",
    "afterPack": "scripts/afterPack.js",
    "icon": "assets/icon",
    "asar": false,
    "files": [
      "electron/**/*",
      "frontend/out/**/*",
      "!**/node_modules"
    ],
    "extraResources": [
      {
        "from": "backend/",
        "to": "backend/"
      },
      {
        "from": "scripts/_checkpoint_download.py",
        "to": "scripts/_checkpoint_download.py"
      },
      {
        "from": "scripts/checkpoints_base.py",
        "to": "scripts/checkpoints_base.py"
      },
      {
        "from": "scripts/checkpoints_extra.py",
        "to": "scripts/checkpoints_extra.py"
      },
      {
        "from": "scripts/runtime.py",
        "to": "scripts/runtime.py"
      },
      {
        "from": "scripts/ml_base.py",
        "to": "scripts/ml_base.py"
      },
      {
        "from": "scripts/ml_extra.py",
        "to": "scripts/ml_extra.py"
      },
      {
        "from": "tests/",
        "to": "tests/"
      },
      {
        "from": "user_data/",
        "to": "user_data/"
      },
      {
        "from": "assets/",
        "to": "assets/"
      },
      {
        "from": "runtime/engine/",
        "to": "runtime/engine/",
        "filter": [
          "**/*",
          "!*/.git/**",
          "!*/tests/**",
          "!*/docs/**",
          "!facefusion/.packages/**",
          "!facefusion/.jobs/**",
          "!facefusion/.assets/**",
          "!facefusion/facefusion.ico",
          "!facefusion/install.py",
          "!facefusion/requirements.txt",
          "!facefusion/facefusion.ini",
          "!fish_speech/docker/**",
          "!fish_speech/compose*.yml",
          "!fish_speech/dockerfile*",
          "!fish_speech/mkdocs.yml",
          "!fish_speech/*.pdf",
          "!fish_speech/*.ipynb",
          "!fish_speech/tools/webui/**",
          "!seed_vc/train.py",
          "!seed_vc/train_v2.py",
          "!seed_vc/data/**",
          "!seed_vc/eval.py",
          "!seed_vc/EVAL.md",
          "!seed_vc/baselines/**",
          "!seed_vc/examples/**",
          "!seed_vc/assets/**",
          "!seed_vc/real-time-gui.py",
          "!seed_vc/app*.py",
          "!seed_vc/conda-*.yaml"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dir",
      "extraResources": [
        {
          "from": "runtime/python/mac/",
          "to": "runtime/python/mac/"
        },
        {
          "from": "runtime/bin/mac/",
          "to": "runtime/bin/mac/"
        }
      ]
    },
    "win": {
      "target": "dir",
      "extraResources": [
        {
          "from": "runtime/python/win/",
          "to": "runtime/python/win/"
        },
        {
          "from": "runtime/bin/win/",
          "to": "runtime/bin/win/"
        }
      ]
    }
  }
}
