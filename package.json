{
  "name": "ai-workshop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "predev": "pkill -f 'next dev' 2>/dev/null; pkill -f 'next-server' 2>/dev/null; pkill -f 'AI Workshop' 2>/dev/null; pkill -f 'electron-builder' 2>/dev/null; true",
    "dev": "concurrently -n 前端,Electron -c cyan,yellow \"cd frontend && pnpm dev\" \"wait-on http://localhost:3000 && npx electron .\"",
    "setup": "mise install && pnpm install && cd frontend && pnpm install && cd ../backend && (mise exec -- poetry install || (mise exec -- poetry lock && mise exec -- poetry install)) && cd .. && mise exec -- python3 scripts/setup_base.py",
    "setup:extra": "mise exec -- python3 scripts/setup_extra.py",
    "ml": "runtime/mac/python/bin/python3 scripts/ml_base.py",
    "ml:extra": "runtime/mac/python/bin/python3 scripts/ml_extra.py",
    "ml:rag": "runtime/mac/python/bin/python3 scripts/ml_extra.py --group rag",
    "ml:agent": "runtime/mac/python/bin/python3 scripts/ml_extra.py --group agent",
    "ml:lora": "runtime/mac/python/bin/python3 scripts/ml_extra.py --group lora",
    "checkpoints": "runtime/mac/python/bin/python3 scripts/checkpoints_base.py",
    "checkpoints:check": "runtime/mac/python/bin/python3 scripts/checkpoints_base.py --check-only",
    "checkpoints:force": "runtime/mac/python/bin/python3 scripts/checkpoints_base.py --force",
    "checkpoints:extra": "runtime/mac/python/bin/python3 scripts/checkpoints_extra.py",
    "build:frontend": "cd frontend && pnpm build",
    "dist:both": "pnpm run build:frontend && electron-builder --mac --win",
    "predist": "pkill -f 'next dev' 2>/dev/null; pkill -f 'next-server' 2>/dev/null; pkill -f 'AI Workshop' 2>/dev/null; pkill -f 'Electron.*test001' 2>/dev/null; true",
    "dist": "pnpm run build:frontend && electron-builder --mac",
    "dist:win": "pnpm run build:frontend && electron-builder --win",
    "docker": "docker compose up --build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-reload": "2.0.0-alpha.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.ai.voice",
    "productName": "AI Workshop",
    "afterPack": "scripts/afterPack.js",
    "icon": "assets/icon",
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "overview.html",
      "overview-preload.js",
      "setup-guide.html",
      "setup-guide-preload.js",
      "scripts/_checkpoint_download.py",
      "scripts/checkpoints_base.py",
      "scripts/checkpoints_extra.py",
      "scripts/setup_base.py",
      "scripts/setup_extra.py",
      "scripts/ml_base.py",
      "scripts/ml_extra.py",
      "frontend/out/**/*",
      "backend/**/*",
      "models/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "runtime/manifest.json",
        "to": "runtime/manifest.json"
      },
      {
        "from": "runtime/rvc/",
        "to": "runtime/rvc/",
        "filter": [
          "**/*",
          "!engine/.git/**",
          "!engine/tests/**",
          "!engine/docs/**"
        ]
      },
      {
        "from": "runtime/fish_speech/",
        "to": "runtime/fish_speech/",
        "filter": [
          "**/*",
          "!engine/.git/**",
          "!engine/docs/**",
          "!engine/docker/**",
          "!engine/compose*.yml",
          "!engine/dockerfile*",
          "!engine/mkdocs.yml",
          "!engine/*.pdf",
          "!engine/*.ipynb",
          "!engine/tests/**",
          "!engine/tools/webui/**"
        ]
      },
      {
        "from": "runtime/seed_vc/",
        "to": "runtime/seed_vc/",
        "filter": [
          "**/*",
          "!engine/.git/**",
          "!engine/train.py",
          "!engine/train_v2.py",
          "!engine/data/**",
          "!engine/eval.py",
          "!engine/EVAL.md",
          "!engine/baselines/**",
          "!engine/examples/**",
          "!engine/assets/**",
          "!engine/real-time-gui.py",
          "!engine/app*.py",
          "!engine/conda-*.yaml"
        ]
      },
      {
        "from": "runtime/whisper/",
        "to": "runtime/whisper/",
        "filter": [
          "**/*",
          "!engine/.git/**",
          "!engine/tests/**",
          "!engine/docs/**"
        ]
      },
      {
        "from": "runtime/faster_whisper/",
        "to": "runtime/faster_whisper/"
      },
      {
        "from": "runtime/got_ocr/",
        "to": "runtime/got_ocr/"
      },
      {
        "from": "runtime/facefusion/",
        "to": "runtime/facefusion/",
        "filter": [
          "**/*",
          "!engine/.git/**",
          "!engine/tests/**",
          "!engine/docs/**"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dir",
      "extraResources": [
        {
          "from": "runtime/mac/python/",
          "to": "runtime/mac/python/"
        },
        {
          "from": "runtime/mac/bin/",
          "to": "runtime/mac/bin/"
        }
      ]
    },
    "win": {
      "target": "dir",
      "extraResources": [
        {
          "from": "runtime/win/python/",
          "to": "runtime/win/python/"
        },
        {
          "from": "runtime/win/bin/",
          "to": "runtime/win/bin/"
        }
      ]
    }
  }
}
